---
const { name, description, thumbnailUrl, uploadDate, contentUrl, embedUrl, duration } = Astro.props;
---

<script type="application/ld+json">
{
  "@context": "http://schema.org",
  "@type": "VideoObject",
  "name": {JSON.stringify(name)},
  "description": {JSON.stringify(description)},
  "thumbnailUrl": {JSON.stringify(thumbnailUrl)},
  "uploadDate": {JSON.stringify(uploadDate)},
  "contentUrl": {JSON.stringify(contentUrl)},
  "embedUrl": {JSON.stringify(embedUrl)},
  "duration": {JSON.stringify(duration)}
}
</script>
