---
const { name, description, thumbnailUrl, uploadDate, contentUrl, embedUrl, duration } = Astro.props;
---

<script type="application/ld+json">
{
  "@context": "http://schema.org",
  "@type": "VideoObject",
  "name": "{name}",
  "description": "{description}",
  "thumbnailUrl": "{thumbnailUrl}",
  "uploadDate": "{uploadDate}",
  "contentUrl": "{contentUrl}",
  "embedUrl": "{embedUrl}",
  "duration": "{duration}"
}
</script>
