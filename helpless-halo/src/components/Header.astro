<style>
/* 
  #page-logo {
    font-style: italic;
  } */
/*
  nav > ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  } */

  nav {
    min-height: 80px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background-color: rgb(42,42,42);
  }

nav ul {
    display: flex;
}

nav ul li {
    height: 100%;
    padding: 30px;
    list-style-type: none;
    border-bottom: 4px solid rgb(42,42,42);
}

/* Farbe der Menuleiste wenn man darauf klickt */
nav ul li:hover {
    border-bottom: 4px solid rgb(111,0,255);
}

/* Schriftgröße der Menubar */
nav ul li a {
    color: white;
    text-decoration: none;
    font-size: 22px;
    font-family: sans-serif;
}

/* Hover Effekt wenn aktiv */
nav ul li .active {
    color: cornflowerblue;
}

  .toggle-button {
    position: absolute;
    top: 25px;
    right: 25px;
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 30px;
    height: 23px;
  }

  /* Dreistrich Menu */
  .toggle-button .bar {
    height: 4px;
    width: 100%;
    background-color: white;
    border-radius: 100px;
    color: var(--color-black);
    background-color: var(--color-white);
  }

  /* Wenn unter 750px dann gelten folgende Regeln */
  @media(max-width:960px) {
    .list-container {
        display: none;
        width: 100%;
    }
    /* Toggle Button wird eingeschaltet */
    .toggle-button {
        display: flex;
    }
    /* Flex direction ist in Spalten */
    nav {
        flex-direction: column;
        align-items: flex-start;
    }
    .list-container ul {
        flex-direction: column;
        width: 100%;
    }
    /* Text wird zentriert */
    .list-container li {
        text-align: center;
    }
    .list-container.active {
        display: flex;
    }

}
</style>

<script is:inline>
document.querySelector("#invertButton").addEventListener("click", () => {
  document.querySelector("body").classList.toggle("invert");

  if (localStorage.getItem("theme") == "invert") {
    localStorage.setItem("theme", "");
  } else {
    localStorage.setItem("theme", "invert");
  }
  });
</script>
