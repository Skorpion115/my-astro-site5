---
//import SecurityPolicy from "../components/SecurityPolicy.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import GoogleTagManager from "../components/GoogleTagManager.astro";
const { pageTitle, description, keywords, href } = Astro.props;
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- 
    <meta name="viewport" content="width=device-width" /> -->
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="manifest" href="/manifest.json" />
    <!-- 
    <link rel="canonical" href="https://www.musicstudio-ziebart.de/" /> -->
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="Language" content="de" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={href} />
    <!--
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; manifest-src 'self'; worker-src 'self'; frame-src 'self' https://www.youtube.com; form-action 'self'; font-src 'self'; img-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline"
    /> -->
    <!--
    <meta
      http-equiv="Content-Security-Policy"
      content="manifest-src 'self'; object-src 'self'; worker-src 'self'; frame-src 'self' https://www.youtube.com; form-action 'self'; font-src 'self'; img-src 'self'; script-src 'self' https://www.googletagmanager.com 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    />-->

    <!--
    <meta http-equiv="Strict-Transport-Scurity: max-age=31536000; includeSubdomains"/> -->
    <!--
    <meta 
      http-equiv="Content-Security-Policy: base-url 'self'; object-src 'none'; font-src 'self'; frame-src 'self' https://www.youtube.com; img-src 'self'; form-action 'self'; worker-src 'self'; manifest-src 'self'; media-src 'self' https://www.youtube.com; script-src 'strict-dynamic' 'unsafe'" 
    />
    <meta http-equiv="Strict-Transport-Security: max-age=63072000; includeSubdomains; preload" />
    <meta http-equiv="X-Frame-Options: SAMEORIGIII" />
    <meta http-equiv="X-XSS-protection: 0" />
    <meta http-equiv="X-Content-Type-Options: nosniff"/> -->
    <meta
      name="google-site-verfication"
      content="Zitul6WICKD7zrzgptxGVrh2GEhozasdEM_d1tGi2aw"
    />
    <meta
      name="author"
      content="Musicstudio Ziebart, postmaster@musicstudio-ziebart.de"
    />
    <meta
      name="DC.Publisher"
      content="Musicstudio Ziebart, postmaster@musicstudio-ziebart.de"
    />
    <meta name="DC.date" content="Collection" />
    <meta name="DC.rights" content="Alle Rechte liegen beim Author" />
    <meta name="revisit-after" content="7 days" />
    <meta name="robots" content="max-snippet:-1" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#191919" />
    <!--
    <script async src="https://www.googletagmanager.com/gtag/js?id=GCXBFDX52C7"></script>-->
    <GoogleTagManager />
  </head>
  <body>
    <Header />
    <h1>{pageTitle}</h1>
    <slot />
    <Footer />
    <!-- Altes Script von Video angeschaut für ServiceWorker -->
    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        if ("serviceWorker" in navigator) {
          navigator.serviceWorker
            .register("/serviceWorker.js", { scope: "/" })
            .then(() => console.log("serviceWorker registered"))
            .catch((error) => console.warn(error));
        }
      });
    </script>
    <script>
      import "../scripts/menu.js";
    </script>
    <script>
      import "../scripts/google.js";
    </script>
  </body>
</html>