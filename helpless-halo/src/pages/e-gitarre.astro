---
import BaseLayout from "../layouts/BaseLayout.astro";
import Scheinhuette from "../../public/e-gitarrenunterricht/scheinhuette-e-gitarrenschule.webp";
import YouTube from "../components/YouTube.astro";
import "../styles/lite-yt-embed.css";
export const prerender = true;
const pageTitle = "E-Gitarrenunterricht für Rockgitarre";
---

<BaseLayout
  pageTitle={pageTitle}
  description="Ich gebe E-Gitarrenunterricht 🎸in nürnberg eibach. E-Gitarre für Anfänger. Gerne auch weiterführende Techniken."
  keywords="e-gitarrenunterricht, ten words - jo satriani, schule der rockgitarre, e gitarrenunterricht nürnberg, e gitarre für anfänger, e gitarrenlehrer in nürnberg"
  href="https://www.musicstudio-ziebart.de/e-gitarre/"
>
  <section>
    <h2>Ten Words - Jo Satriani</h2>
    <div class="video-container-wrapper">
      <div class="video-container">
        <lite-youtube
          videoid="8ucTzPOBzAo"
          style="background-image: url('https://i.ytimg.com/vi/8ucTzPOBzAo/hqdefault.jpg');"
        >
          <a
            href="https://www.youtube.com/embed/vxX0WiQhSUE?si=8ucTzPOBzAo"
            class="lty-playbtn"
            title="Joe Satriani - Ten Words Guitar Lesson+Tab"
          >
            <span class="lyt-visually-hidden"
              >Play Video: Keynote (Google I/O '18)</span
            >
          </a>
        </lite-youtube>
      </div>
    </div>
    <article>
      <h2>Schule der Rockgitarre, Andreas Scheinhütte</h2>
      <p>
        <img
          src={Scheinhuette.src}
          width={Scheinhuette.width}
          height={Scheinhuette.height}
          alt="Bild SEO E-Gitarrenschule von Andreas Scheinhuette"
          aria-label="Bild SEO E-Gitarrenschule von Andreas Scheinhütte"
        />
      </p>
      <p>
        Für die E-Gitarre gibt es eine tolle E-Gitarrenschule von Andreas
        Scheinhütte. Das Werk heißt "Schule der Rockgitarre". Es ist eine CD zum
        mitspielen dabei! Es gibt 2 Bänder davon.
      </p>
      <p>
        Ein tolles Stück um eine E-Gitarre zu respräsentieren ist das Stück von
        Jo Satriani "Ten Words". Ich habe es mal aufgenommen und auf YouTube
        gestellt.
      </p>
      <p>
        <a href="/leistungen/" class="normal-links">zurück</a>
      </p>
    </article>
  </section>
</BaseLayout>

<YouTube />

<style>
  section article img {
    max-width: 30%;
    height: auto;
    box-shadow: 0px 0px 10px 5px #4c4948;
    border-radius: 5px;
    float: right;
    margin-top: 1.25rem;
    margin-left: 1rem;
    margin-right: 3rem;
  }
</style>
