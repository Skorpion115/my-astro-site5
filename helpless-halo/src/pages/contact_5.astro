---
import Layout from "../layouts/Layout.astro";
---

<Layout title="contact_5" description="Probeunterricht" keywords="Contact">
    <div class="container4">
        <form name="contact_5" action="thanks/" method="POST" data-netlify-recaptcha="true" data-netlify="true">
            <p>
              <label>Name <input type="text" name="name" required /></label>
            </p>
            <p>
              <label>Email <input type="email" name="email" /></label>
            </p>
            <p>
            <label for="phone">Telefonnummer</label>
                <input
                type="tel"
                id="phone"
                name="phone"
                class="form-control form-control-lg" required
                />
            </p>
            <p>
                <label for="message">Nachricht</label>
                <textarea
                  id="message"
                  name="message"
                  cols="23"
                  rows="10"
                  placeholder="Was kann ich für Sie tun?"></textarea> 
            </p>
            <p>
              <button type="submit">Senden</button>
            </p>
          </form>




    </div>










</Layout>

<style>
    .container4 {
    margin: 0 auto;
    padding: 5%;
    box-sizing: border-box;
  }

  body {
    font-family: var(--font);
    color: var(--color-black);
    background-color: var(--color-schwarz);
    text-align: center;
  }

  label {
    display: block;
    font-size: 1.125rem;
    padding: 0.625rem;
  }

  /* Der Rand um die Felder */
  .form-control {
    border-radius: 0px;
    border: 1px solid #333;
  }

  /* Die Breite der Felder */
  .form-control.form-control-lg {
    height: calc(3.5rem + 2px);
    padding: 1rem 0.75rem;
    font-size: 1.125rem;
  }


</style>