<style>
  /* ANCHOR Bilder Scrolling mit JavaScript */
  .container {
    display: inline-block;
    height: auto;
    width: 96%;
    max-width: 960px;
    padding: 0.5rem;
  }

  .section {
    margin-bottom: 1.25rem;
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: bold;
    margin-bottom: 0.625rem;
  }

  .image-scroll {
    display: flex;
    overflow-x: auto;
    overflow: hidden;
    box-shadow: 2px 2px 5px #666;
  }

  .image-scroll-inner {
    display: flex;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .image-scroll-inner::-webkit-scrollbar {
    display: none;
  }

  .image-scroll-inner::-webkit-scrollbar {
    display: none;
  }

  .image-scroll img {
    height: auto;
    max-width: 100%;
    margin-right: 0px;
    object-fit: cover;
  }

  /* ANCHOR Animation */
  .animation {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  .animation {
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 3%;
    width: 100%;
    margin: 0 auto;
    /* Höhe der Border-Box, legt die Mindesthöhe eines Elements fest*/
    /* Relativ zu 1 % der Breite des Ansichtsfensters */
    min-height: 10vw;
    background: #252839;
  }

  h3 {
    position: relative;
    /* Schriftgröße dahinter vw ist responsiv*/
    font-size: 4vw;
    color: #252839;
    /* gibt die Breite und die Farbe von Strichen an Schrift dahinter*/
    -webkit-text-stroke: 0.1vw #383d52;
    /* Es wird alles groß geschrieben */
    text-transform: uppercase;
  }

  h3::before {
    content: attr(data-text);
    position: absolute;
    /* Schriftweite davor die läuft vw ist responsiv gegenüber px */
    font-size: 4vw;
    /* Text bleibt bei 1 am Ende stehen, bei 0 ist es leer */
    width: 1;
    /* Höhe des Cursors */
    height: 110%;
    color: #01f387;
    /* Breite und Farbe des laufenden Textes Schrift davor*/
    -webkit-text-stroke-width: 0.1vw #383d52;
    /* Die Stärke des Strichs */
    border-right: 2px solid #01fe87;
    overflow: hidden;
    animation: animate 6s 3 linear;
  }

  @keyframes animate {
    0%,
    10%,
    100% {
      width: 0;
    }
    70%,
    90% {
      width: 100%;
    }
  }

  /* ANCHOR Hauptseite */
  .conteneur {
    border: 0px solid black;
    align-content: space-between;
    width: 94vw;
    font-style: normal;
    display: flex;
    justify-content: flex-start;
    align-items: flex-start;
    flex-wrap: wrap;
    align-content: flex-start;
  }

  /* Container Inhalt */
  .marchandise {
    padding: 0.625rem;
  }

  /* Kind Elemente */
  .marchandise-1 {
    flex: 2;
  }

  .marchandise-2 {
    flex: 1;
  }

  /* Card Position*/

  .marchandise-2 .link-card-grid {
    padding: 0.5rem;
  }

  /* Balken für Klavierunterricht usw.*/

  .marchandise-1 ul {
    padding-right: 3rem;
  }

  .conteneur ul li {
    height: 3rem;
    box-shadow: 2px 2px 5px #666;
    margin-top: 15px;
    /* oben und unten 0.3rem, rechts und links 1.875rem */
    padding: 0.3rem 1.875rem;
    font-size: large;
    /* Keine Punkte vor den Ul's */
    list-style-type: none;
  }

  /* Rudi.jpg */

  .conteneur img {
    width: 100%;
    height: auto;
    max-width: 100%;
    padding: 2rem;
    box-shadow: 2px 2px 5px #666;
  }

