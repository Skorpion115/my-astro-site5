<style>
  #download {
    display: block;
    width: 96%;
    max-width: 100%;
    margin: 7% auto;
    padding: 1.25em;
    text-align: center;
    font-style: normal;
  }

  #download article {
    display: inline-block;
    width: 96%;
    vertical-align: top;
  }

  /* ANCHOR Neue Table CSS */

  * {
    box-sizing: border-box;
    font-size: calc(1rem + var(--font-scale));
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      "Open Sans",
      "Helvetica Neue",
      sans-serif;
  }

  table.basis-table {
    border-collapse: collapse;
    margin: 32px 0;
    min-width: 400px;
    border-radius: 5px 5px 0 0;
    font-weight: normal;
    overflow: hidden;
    text-align: left;
  }

  table.basis-table thead tr {
    background-color: rebeccapurple;
    color: white;
  }

  table.basis-table th,
  table.basis-table td {
    padding: 12px 16px;
  }

  table.basis-table tbody tr {
    border-bottom: 1px solid #ccc;
  }

  table.basis-table tbody tr:last-of-type {
    border-bottom: 2px solid rebeccapurple;
  }

  table.basis-table tbody tr.active {
    font-weight: bold;
    color: rebeccapurple;
  }

  #download article p {
    margin: 0em;
    text-align: left;
  }

  #download article h3 {
    margin-left: 3%;
    font-size: 1.25rem;
  }

  /* ANCHOR Variante B */
  @media screen and (max-width: 578px) {
    table.basis-table th:nth-child(3),
    table.basis-table td:nth-child(3) {
      display: none;
    }
  }
</style>
