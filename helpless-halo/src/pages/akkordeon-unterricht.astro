---
import BaseLayout from "../layouts/BaseLayout.astro";
import Holzschuh from "../../public/images/holzschuh-wide.webp";
export const prerender = true;
const pageTitle = 'Akkordeon Unterricht';
---

<BaseLayout
  pageTitle={pageTitle}
  description="Ich gebe Akkordeonunterricht in eibach"
  keywords="akkordeonunterricht, akkordeon unterricht, akkordeon privatunterricht, akkordeon lernen nürnberg, akkordeon lernen, akkordeon spielen lernen, akkordeon lernen anfänger, akkordeon, akkordeon kurs, akkordeon spielen, akkordeonunterricht für erwachsene, accordion lesson"
  href="https://www.musicstudio-ziebart.de/akkordeon-unterricht/"
>
  <section>
    <article>
      <h2>Alfons Holzschuh</h2>
        <img
          src={Holzschuh.src}
          width={Holzschuh.width}
          height={Holzschuh.height}
          alt="Akkordeonschule von Alfons Holzschuh"
        />
      <p>
        Für den Akkordeonunterricht nehme ich am Anfang die Akkordeonschule von
        Alfons Holzschuh. Es gibt davon 2 Bänder. Das Akkordeon war früher das
        Top Instrument. Man kann damit hervoragend Volksmusik spielen. Für
        Französiche Musette Stücke oder Tangos wird das Akkordeon gerne
        eingesetzt. Heute ist das immernoch so! Dann gibt es von Heinz Munsonius
        ganz berühmte Akkordeon Klassiker wie Tanzende Finger zum Beispiel.
      </p>
      <br />
      <p>
        <a href="/leistungen/" class="normal-links">zurück</a>
      </p>
    </article>
  </section>
</BaseLayout>
