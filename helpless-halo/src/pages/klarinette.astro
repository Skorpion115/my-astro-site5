---
import BaseLayout from "../layouts/BaseLayout.astro";
import Koch from "../../public/klarinettenunterricht/koch-klarinettenschule.webp";
export const prerender = true;
const pageTitle = "Klarinettenunterricht für Böhm und Deutsches System";
---

<BaseLayout
  pageTitle={pageTitle}
  description="Ich gebe Klarinettenunterricht 🎼 in Nürnberg. Ich benutze sowohl das Böhmsystem als auch das deutsche System"
  keywords="klarinettenunterricht f&uuml;r boem und deutsche system, klarinettenunterricht, neue schule für klarinette ewald koch, klarinette lernen, klarinettenunterricht n&uuml;rnberg, klarinettenschule, klarinette lernen, klarinettenschule für anfaenger, musikschule klarinette, klarinettenunterricht in n&uuml;rnberg, klarinettenunterricht in eibach, klarinette, klarinettenunterricht, klarinette für anfaenger, klarinettenkurs, musikschule für klarinette, klarinettenunterricht eibach, unterricht klarinette, musikunterricht klarinette, klarinettenlehrer, Klarinette lernen für anfaenger"
  href="https://www.musicstudio-ziebart.de/klarinette/"
>
  <article>
    <section>
      <h2>Neue Schule für Klarinette, Ewald Koch</h2>
      
      <img
        src={Koch.src}
        width={Koch.width}
        height={Koch.height}
        alt="Bild SEO Neue Schule für Klarinette von Ewald Koch"
        aria-label="Bild SEO Neue Schule für Klarinette von Ewald Koch"
      />
      <p>
        Für den Klarinettenunterricht benutze ich gerne die Schule vom Professor
        Ewald Koch mit dem Titel: "Neue Schule für Klarinette". Es gibt 2 Bänder
        davon und eine CD ist ebenfalls dabei. Ein riesen Werk kann ich nur
        sagen.
      </p>      
      <p>
        <a href="/instrumentenkauf/" class="normal-links">Mehr Info über die Klarinette</a>
      </p>     
      <br />
      <br />
      <p>
        <a href="/leistungen/" class="normal-links">zurück</a>
      </p>
    </section>
  </articel>
</BaseLayout>

<style>
  article section img {
    max-width: 30%;
    height: auto;
    border-radius: 5px;
    float: right;
    margin-top: 1.25rem;
    margin-left: 1rem;
    margin-right: 3rem;
  }
</style>
