---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "Tabelle";
---

<BaseLayout
  pageTitle={pageTitle}
  description="Midi Files und Noten bekannter Werke komplett zu downloaden! Mondschein Sonate, Eine kleine Nachtmusik, Die Fledermaus, Schwannensee"
  keywords="Download, Midi Files und Noten bekannter Werke zum downloaden"
  href="https://www.musicstudio-ziebart.de/tabelle/"
>

<table class="content">
    <thead>
        <tr>
            <th>ID</th>
            <th>Vorname</th>
            <th>Nachname</th>
            <th>Email</th>
            <th>Beruf</th>
            <th>Alter</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>1</td>
            <td>Max</td>
            <td>Mustermann</td>
            <td>max@email.de</td>
            <td>Entwickler</td>
            <td>25</td>
        </tr>
        <tr class="active">
            <td>2</td>
            <td>John</td>
            <td>Doe</td>
            <td>john@email.de</td>
            <td>Designer</td>
            <td>26</td>
        </tr>
        <tr>
            <td>3</td>
            <td>Tim</td>
            <td>Taylor</td>
            <td>tim@email.de</td>
            <td>Koch</td>
            <td>27</td>
        </tr>
    </tbody>
</table>
<!-- Variante A -->
<div class="basis-card">
    <div class="basis-header"> ID: 1</div>
    <div><span>Vorname:</span> Max</div>
    <div><span>Nachname:</span> Mustermann</div>
    <div><span>E-Mail:</span> max@email.de</div>
    <div><span>Beruf:</span> Entwickler</div>
    <div><span>Alter:</span> 25 Jahre alt</div>
</div>
<div class="basis-card">
    <div class="basis-header"> ID: 2</div>
    <div><span>Vorname:</span> John</div>
    <div><span>Nachname:</span> Doe</div>
    <div><span>E-Mail:</span> john@email.de</div>
    <div><span>Beruf:</span> Designer</div>
    <div><span>Alter:</span> 26 Jahre alt</div>
</div>
<div class="basis-card">
    <div class="basis-header"> ID: 3</div>
    <div><span>Vorname:</span> Tim</div>
    <div><span>Nachname:</span> Taylor</div>
    <div><span>E-Mail:</span> tim@email.de</div>
    <div><span>Beruf:</span> Koch</div>
    <div><span>Alter:</span> 27 Jahre alt</div>
</div>

</BaseLayout>

<style>
table.content {
    box-sizing: border-box;
    font-size: 1rem;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;

}   
table.content {
    border-collapse: collapse;
    margin: 32px 0;
    min-width: 400px;
    border-radius: 5px 5px 0 0;
    font-weight: normal;
    overflow: hidden;
    text-align: left;
}

table.content thead tr {
    background-color: rebeccapurple;
    color: white;
}

table.content th,
table.content td {
    padding: 12px 16px;
}

table.content tbody tr {
    border-bottom: 1px solid #ccc;
}

table.content tbody tr:last-of-type {
    border-bottom: 2px solid rebeccapurple;
}

table.content tbody tr.active {
    font-weight: bold;
    color: rebeccapurple;
}

/* ANCHOR Variante A */
.basis-card {
    display: none;
    width: 100%;
    margin-bottom: 20px;
}

.basis-header {
    background-color: rebeccapurple;
    color: white;
    border-radius: 5px 5px 0 0;
    padding: 10px;
    font-weight: bold;
}

.basis-card div {
    padding: 10px;
    border-bottom: 1px solid #ccc;
}

.basis-card div:last-of-type {
    border-bottom: 2px solid rebeccapurple;
}

.basis-card div > span {
    color: rebeccapurple;
    font-weight: bold;
}

@media screen and (max-width: 578px) {
    table.basis-table {
        display: none;
    }

    .basis-card {
        display: block;
    }
}
</style>