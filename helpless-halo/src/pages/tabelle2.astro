---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "Tabelle";
---

<BaseLayout
  pageTitle={pageTitle}
  description="Midi Files und Noten bekannter Werke komplett zu downloaden! Mondschein Sonate, Eine kleine Nachtmusik, Die Fledermaus, Schwannensee"
  keywords="Download, Midi Files und Noten bekannter Werke zum downloaden"
  href="https://www.musicstudio-ziebart.de/tabelle/"
>

<table class="content">
    <thead>
        <tr>
            <th>ID</th>
            <th>Vorname</th>
            <th>Nachname</th>
            <th>Email</th>
            <th>Beruf</th>
            <th>Alter</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>1</td>
            <td>Max</td>
            <td>Mustermann</td>
            <td>max@email.de</td>
            <td>Entwickler</td>
            <td>25</td>
        </tr>
        <tr class="active">
            <td>2</td>
            <td>John</td>
            <td>Doe</td>
            <td>john@email.de</td>
            <td>Designer</td>
            <td>26</td>
        </tr>
        <tr>
            <td>3</td>
            <td>Tim</td>
            <td>Taylor</td>
            <td>tim@email.de</td>
            <td>Koch</td>
            <td>27</td>
        </tr>
    </tbody>
</table>
<!-- Variante A -->


</BaseLayout>

<style>
table.content {
    box-sizing: border-box;
    font-size: 1rem;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;

}   
table.content {
    border-collapse: collapse;
    margin: 32px 0;
    min-width: 400px;
    border-radius: 5px 5px 0 0;
    font-weight: normal;
    overflow: hidden;
    text-align: left;
}

table.content thead tr {
    background-color: rebeccapurple;
    color: white;
}

table.content th,
table.content td {
    padding: 12px 16px;
}

table.content tbody tr {
    border-bottom: 1px solid #ccc;
}

table.content tbody tr:last-of-type {
    border-bottom: 2px solid rebeccapurple;
}

table.content tbody tr.active {
    font-weight: bold;
    color: rebeccapurple;
}

/* ANCHOR Variante B */
@media screen and (max-width: 578px) {
   table.basis-table th:nth-child(5),
   table.basis-table td:nth-child(5),
   table.basis-table th:nth-child(6),
   table.basis-table td:nth-child(6) {
    display: none;
   }
}

</style>