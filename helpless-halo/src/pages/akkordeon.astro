---
import BaseLayout from "../layouts/BaseLayout.astro";
import Holzschuh from "../../public/akkordeonunterricht/holzschuh-akkordeonschule.webp";
export const prerender = true;
const pageTitle = "Akkordeon Unterricht mit Tasten";
---

<BaseLayout
  pageTitle={pageTitle}
  description="Ich gebe Akkordeonunterricht in Eibach. Benutze dazu die Akkordeonschule von Alfons Holzschuh Band 1 und 2. 🎹"
  keywords="akkordeon unterricht, alfons holzschuh, akkordeonunterricht nürnberg, akkordeon lernen online, akkordeon privatunterricht, akkordeon lernen nürnberg, akkordeon lernen, akkordeon spielen lernen, akkordeon lernen anfänger, akkordeon, akkordeon kurs, akkordeon spielen, akkordeonunterricht für erwachsene, accordion lesson"
  href="https://www.musicstudio-ziebart.de/akkordeon/"
>
  <section>
    <article>
      <h2>Alfons Holzschuh</h2>
        <img
          src={Holzschuh.src}
          width={Holzschuh.width}
          height={Holzschuh.height}
          alt="Bild SEO Akkordeonschule von Alfons Holzschuh"
          aria-label="Bild SEO Akkordeonschule von Alfons Holzschuh"
        />
      <p>
        Für den Akkordeonunterricht nehme ich am Anfang die Akkordeonschule von
        Alfons Holzschuh. Es gibt davon 2 Bänder. Das Akkordeon war früher das
        Top Instrument. Man kann damit hervoragend Volksmusik spielen. Für
        Französiche Musette Stücke oder Tangos wird das Akkordeon gerne
        eingesetzt. Heute ist das immernoch so! Dann gibt es von Heinz Munsonius
        ganz berühmte Akkordeon Klassiker wie Tanzende Finger zum Beispiel.
      </p>
      <br />
      <p>
        <a href="/leistungen/" class="normal-links">zurück</a>
      </p>
    </article>
  </section>
</BaseLayout>

<style>
  section article img {
    max-width: 30%;
    height: auto;
    box-shadow: 0px 0px 10px 5px #4c4948;
    border-radius: 5px;
    float: right;
    margin-top: 1.25rem;
    margin-left: 1rem;
    margin-right: 3rem;
  }
</style>
