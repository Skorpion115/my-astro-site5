<style>
  #download2 {
    display: block;
    width: 96%;
    max-width: 100%;
    margin: 7% auto;
    padding: 1.25rem;
    text-align: center;
    font-style: normal;
  }

  #download2 article {
    display: inline-block;
    width: 96%;
    vertical-align: top;
  }

  
  /* ANCHOR Neue basis-table CSS */

table.basis-table {
    border-collapse: collapse;
    margin: 32px 0;
    min-width: 400px;
    border-radius: 5px 5px 0 0;
    font-weight: normal;
    overflow: hidden;
    text-align: left;
}

table.basis-table thead tr {
    background-color: rebeccapurple;
    color: white;
}

table.basis-table th,
table.basis-table td {
    padding: 12px 16px;
}

table.basis-table tbody tr {
    border-bottom: 1px solid #ccc;
}

table.basis-table tbody tr:last-of-type {
    border-bottom: 2px solid rebeccapurple;
}

table.basis-table tbody tr.active {
    font-weight: bold;
    color: rebeccapurple;
}

/* ANCHOR basis-card CSS */
.basis-card {
    display: none;
    width: 100%;
    margin-bottom: 20px;
}

.basis-header {
    background-color: rebeccapurple;
    color: white;
    border-radius: 5px 5px 0 0;
    padding: 10px;
    font-weight: bold;
}

.basis-card div {
    padding: 10px;
    border-bottom: 1px solid #ccc;
}

.basis-card div:last-of-type {
    border-bottom: 2px solid rebeccapurple;
}

.basis-card div > span {
    color: rgb(218, 54, 54);
    font-weight: bold;
}

@media screen and (max-width: 578px) {
    table.basis-table {
        display: none;
    }

    .basis-card {
        display: block;
    }
}

  #download2 article p {
    margin: 0em;
    text-align: left;
  }
</style>
