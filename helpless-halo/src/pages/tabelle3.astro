---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "Tabelle3";
---

<BaseLayout
  pageTitle={pageTitle}
  description="Midi Files und Noten bekannter Werke komplett zu downloaden! Mondschein Sonate, Eine kleine Nachtmusik, Die Fledermaus, Schwannensee"
  keywords="Download, Midi Files und Noten bekannter Werke zum downloaden"
  href="https://www.musicstudio-ziebart.de/tabelle3/"
>

<table class="content">
    <thead>
        <tr>
            <th>ID</th>
            <th>Vorname</th>
            <th>Nachname</th>
            <th>Email</th>
            <th>Beruf</th>
            <th>Alter</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td data-label="ID">1</td>
            <td data-label="Vorname">Max</td>
            <td data-label="Nachname">Mustermann</td>
            <td data-label="Email">max@email.de</td>
            <td data-label="Beruf">Entwickler</td>
            <td data-label="Alter">25</td>
        </tr>
        <tr class="active">
            <td data-label="ID">2</td>
            <td data-label="Vorname">John</td>
            <td data-label="Nachname">Doe</td>
            <td data-label="Email">john@email.de</td>
            <td data-label="Beruf">Designer</td>
            <td data-label="Alter">26</td>
        </tr>
        <tr>
            <td data-label="ID">3</td>
            <td data-label="Vorname">Tim</td>
            <td data-label="Nachname">Taylor</td>
            <td data-label="Email">tim@email.de</td>
            <td data-label="Beruf">Koch</td>
            <td data-label="Alter">27</td>
        </tr>
    </tbody>
</table>


</BaseLayout>

<style>
table.content {
    box-sizing: border-box;
    font-size: 1rem;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;

}   
table.content {
    border-collapse: collapse;
    margin: 32px 0;
    min-width: 400px;
    border-radius: 5px 5px 0 0;
    font-weight: normal;
    overflow: hidden;
    text-align: left;
}

table.content thead tr {
    background-color: rebeccapurple;
    color: white;
}

table.content th,
table.content td {
    padding: 12px 16px;
}

table.content tbody tr {
    border-bottom: 1px solid #ccc;
}

table.content tbody tr:last-of-type {
    border-bottom: 2px solid rebeccapurple;
}

table.content tbody tr.active {
    font-weight: bold;
    color: rebeccapurple;
}

/* ANCHOR Variante C */
@media screen and (max-width: 578px) {
    table.basis-table thead {
        display: none;
    }

    table.basis-table tbody tr {
        display: block;
        margin-bottom: 20px;
    }

    table.basis-table tbody tr:last-of-type {
        border-bottom: 1px solid #ccc;
    }

    table.basis-table tbody td {
        display: block;
    }

    table.basis-table tbody td::before {
        content: attr(data-label) ": ";
        display: inline-block;
        min-width: 200px;
    }
}
</style>